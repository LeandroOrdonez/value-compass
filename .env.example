# Copy this file to .env and replace the placeholder values before running docker compose.

# Database credentials (required)
POSTGRES_USER=valuecompass
# Generate a strong password, e.g. `openssl rand -base64 24`
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=valuecompass

# JWT signing secret (required, must be at least 32 characters)
# Generate with: `openssl rand -hex 32`
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars

DATA_SOURCE=yahoo
ENVIRONMENT=development
NEXT_PUBLIC_API_URL=http://localhost:8000
